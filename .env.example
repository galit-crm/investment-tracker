# ─── Investment Tracker — Environment Variables Reference ────────────────────
#
# FOR DEVELOPMENT: copy to .env and fill in values
# FOR PRODUCTION:  set these in Render dashboard (backend) and Vercel dashboard (frontend)
#                  Never commit real secrets to git.
#
# Generate secrets with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database ─────────────────────────────────────────────────────────────────
# Dev:  postgresql://postgres:password@localhost:5432/investment_tracker
# Prod: copy from Neon dashboard → Connection Details → Pooled connection string
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# ─── JWT ─────────────────────────────────────────────────────────────────────
# REQUIRED in production — use long random strings (48+ bytes hex)
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Encryption ───────────────────────────────────────────────────────────────
# REQUIRED — used for AES-256-GCM encryption of broker API credentials in DB
# MUST be exactly 32 ASCII characters. Changing this breaks existing credentials.
ENCRYPTION_KEY="32-char-key-change-in-production!"

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV="production"
# API_PORT is optional in production — Render sets PORT automatically
API_PORT=3001
API_PREFIX="api/v1"
# Your Vercel frontend URL (no trailing slash)
FRONTEND_URL="https://your-app.vercel.app"

# ─── Rate Limiting ────────────────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ─── Market Data Providers ────────────────────────────────────────────────────
# Yahoo Finance — no API key needed for basic use
YAHOO_FINANCE_ENABLED=true

# Alpha Vantage — optional
ALPHA_VANTAGE_API_KEY=""
ALPHA_VANTAGE_ENABLED=false

# Twelve Data — optional
TWELVE_DATA_API_KEY=""
TWELVE_DATA_ENABLED=false

# CoinGecko — free tier works without key; Pro key increases rate limits
COINGECKO_API_KEY=""
COINGECKO_ENABLED=true

# In-memory market data cache TTL in seconds
MARKET_DATA_CACHE_TTL_SECONDS=300

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com → APIs → Credentials
# Authorized redirect URI must be: https://<api-domain>/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="https://your-api.onrender.com/api/v1/auth/google/callback"

# ─── Email (password reset) ───────────────────────────────────────────────────
# Gmail: enable 2FA, then create an App Password at myaccount.google.com/apppasswords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="noreply@your-domain.com"

# ─── News ─────────────────────────────────────────────────────────────────────
# CryptoCompare API key — optional, increases news rate limits
NEWS_CRYPTOCOMPARE_API_KEY=""

# ─── Logging ─────────────────────────────────────────────────────────────────
# Use "warn" or "error" in production to reduce noise
LOG_LEVEL="warn"

# ─── Frontend — set in Vercel dashboard as environment variable ───────────────
# (not used by the backend — only needed in apps/web)
NEXT_PUBLIC_API_URL="https://your-api.onrender.com/api/v1"
